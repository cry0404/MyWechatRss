# 复制本文件为 .env 后填写。勿将 .env 提交到公开仓库。
# Copy to .env and fill in. Do not commit .env to git.

# ----- 必改：随机密钥（各至少 16 字符；可用: openssl rand -hex 32）-----
APP_SECRET=
JWT_SECRET=

# ----- 必改：上游私有服务（由服务提供方给你）-----
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY_ID=
UPSTREAM_API_SECRET=

# ----- 必改：你访问本站的根地址（含协议，无末尾 /；RSS 与邮件链接依赖此项）-----
PUBLIC_BASE_URL=http://127.0.0.1:8081

# ----- 首次启动：空库时自动创建管理员（登录后请到设置改密）-----
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=changeme
BOOTSTRAP_EMAIL=you@example.com

# ----- 选填 -----
# 宿主机映射端口（与 docker-compose 中 HOST_PORT 一致时生效；默认 8081）
# HOST_PORT=8081


# 邮件提醒（全部账号失效时）；不配则仅记日志不发信
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=false
